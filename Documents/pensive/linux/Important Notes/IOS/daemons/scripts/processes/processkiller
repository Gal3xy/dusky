#!/bin/sh
# ProcessKiller - Simple, reliable background process killer

KILL_LIST="PosterBoard CollectionsPoster PhotosPosterProvider UnityPosterExtension EmojiPosterExtension GradientPosterExtension WeatherPoster AegirPoster ExtragalacticPoster Spotlight tipsd bookassetd weatherd SiriTTSSynthesizerAU"
INTERVAL=5

case "$1" in
    start)
        # Kill existing instances
        for pid in $(ps aux 2>/dev/null | grep -v grep | grep "processkiller start" | cut -c10-14 2>/dev/null); do
            kill -9 $pid 2>/dev/null
        done
        sleep 1
        
        # Start killer loop in background
        (
            while :; do
                for proc in $KILL_LIST; do
                    killall -9 $proc 2>/dev/null
                done
                sleep $INTERVAL
            done
        ) &
        
        sleep 1
        echo "ProcessKiller started (PID: $!)"
        ;;
    stop)
        for pid in $(ps aux 2>/dev/null | grep -v grep | grep "processkiller start" | cut -c10-14 2>/dev/null); do
            kill -9 $pid 2>/dev/null
        done
        echo "ProcessKiller stopped"
        ;;
    status)
        echo ""
        echo "=== ProcessKiller Status ==="
        echo ""
        COUNT=$(ps aux 2>/dev/null | grep -v grep | grep -c "processkiller start" 2>/dev/null || echo 0)
        if [ "$COUNT" -gt 0 ]; then
            echo "Status: RUNNING"
        else
            echo "Status: NOT RUNNING"
        fi
        echo ""
        echo "Processes: $KILL_LIST"
        echo ""
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    install)
        # Create launchd plist for auto-start
        cat > /var/jb/Library/LaunchAgents/com.test.processkiller.plist << 'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.test.processkiller</string>
    <key>ProgramArguments</key>
    <array>
        <string>/var/jb/basebin/processkiller</string>
        <string>start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
PLIST
        chmod 644 /var/jb/Library/LaunchAgents/com.test.processkiller.plist
        launchctl load /var/jb/Library/LaunchAgents/com.test.processkiller.plist 2>/dev/null
        echo "Auto-start installed!"
        ;;
    uninstall)
        launchctl unload /var/jb/Library/LaunchAgents/com.test.processkiller.plist 2>/dev/null
        rm -f /var/jb/Library/LaunchAgents/com.test.processkiller.plist
        $0 stop
        echo "Auto-start removed!"
        ;;
    *)
        echo "ProcessKiller - Background process killer"
        echo ""
        echo "Usage:"
        echo "  processkiller start      - Start killing"
        echo "  processkiller stop       - Stop"
        echo "  processkiller status    - Check status"
        echo "  processkiller restart   - Restart"
        echo "  processkiller install   - Auto-start on boot"
        echo "  processkiller uninstall  - Remove auto-start"
        ;;
esac
